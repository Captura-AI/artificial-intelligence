# ── Captura AI Service — Environment Variables ──────────────────────────────

# Application
APP_NAME=Captura AI Service
APP_VERSION=1.0.0
DEBUG=false

# Model configuration
# YOLOv8 weights file — 'yolov8n.pt' is downloaded automatically on first run
YOLO_MODEL_PATH=yolov8n.pt

# CLIP model variant: ViT-B/32 (smaller/faster) or ViT-L/14 (larger/better)
CLIP_MODEL_NAME=ViT-B/32

# Minimum confidence to report a vehicle detection (0.0 – 1.0)
VEHICLE_CONFIDENCE_THRESHOLD=0.5

# Minimum confidence to report a license plate reading (0.0 – 1.0)
PLATE_CONFIDENCE_THRESHOLD=0.4

# Languages for EasyOCR (comma-separated ISO codes)
OCR_LANGUAGES=["en","id"]